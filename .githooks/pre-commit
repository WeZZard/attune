#!/bin/sh
# Attune pre-commit gate. Enable per clone with:
#   git config core.hooksPath .githooks
set -e

cd "$(git rev-parse --show-toplevel)"

node --check hooks/session-start-communication.mjs
node --check hooks/session-start-external-agents.mjs
node --check scripts/check-hook-budget.mjs
node --check scripts/probe-capabilities.mjs
node -e "JSON.parse(require('fs').readFileSync('capabilities.json','utf8'))"
node --test --test-reporter=dot scripts/*.test.mjs
node scripts/check-hook-budget.mjs

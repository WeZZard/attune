#!/bin/sh
# Attune pre-commit gate. Enable per clone with:
#   git config core.hooksPath .githooks
set -e

cd "$(git rev-parse --show-toplevel)"

node --check extensions/attune.js
node --check hooks/_lib.mjs
node --check hooks/session-start-communication.mjs
node --check hooks/session-start-writing.mjs
node --check scripts/_agents-core.mjs
node --check scripts/_detect-external-agents.mjs
node --check scripts/_probe-capabilities.mjs
node --check scripts/_matrix.mjs
node --check utils/_check-hook-budget.mjs
node --check utils/_check-plugins.mjs
node --check utils/_generate-platform-assets.mjs
node --check utils/_porting.mjs
node -e "JSON.parse(require('fs').readFileSync('capabilities.json','utf8'))"
node -e "JSON.parse(require('fs').readFileSync('porting.json','utf8'))"
node --test --test-reporter=dot scripts/*.test.mjs extensions/*.test.mjs utils/*.test.mjs
sh utils/generate-platform-assets.sh --check
sh utils/check-hook-budget.sh
sh utils/check-plugins.sh
